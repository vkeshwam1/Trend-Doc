pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning TrendStore repository...'
                git branch: 'main', url: 'https://github.com/vkeshwam1/Trend.git'
            }
        }
        stage('Docker Build') {
            steps {
                echo 'Building Docker image...'
                sh 'docker build -t vkeshwam1/trend-app:latest .'
                sh 'docker images | grep trend-app'
            }
        }
        stage('Deploy to EKS') {
            steps {
                echo 'Deploying to EKS...'
                sh 'kubectl apply -f k8s/deployment.yaml'
                sh 'kubectl apply -f k8s/service.yaml'
                sh 'kubectl get pods'
                sh 'kubectl get svc'
            }
        }
    }
    post {
        success { echo 'Deployment SUCCESS!' }
        failure { echo 'Deployment FAILED!' }
    }
}
 
    

  
